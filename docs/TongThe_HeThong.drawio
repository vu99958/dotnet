<mxfile host="app.diagrams.net">
  <diagram name="TongThe_HeThong" id="system_flow_01">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="800" math="0" shadow="0">
      <root>
